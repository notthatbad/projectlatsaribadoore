# Salin file ini menjadi `.env` lalu isi GEMINI_API_KEY milikmu.
# JANGAN commit file `.env` asli (sudah di-gitignore).

GEMINI_API_KEY=isi_api_key_gemini_di_sini

# Model TEKS (analisis, deskripsi & caption).
# Contoh valid: gemini-2.5-flash (stabil), gemini-3.5-flash, gemini-2.5-pro
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Model GAMBAR (media visual). WAJIB model yang mendukung output IMAGE.
# Pilihan yang bagus untuk infografis/poster (teks di gambar lebih rapi):
#   gemini-2.5-flash-image   -> "Nano Banana", stabil & cepat (default)
#   gemini-3-pro-image       -> kualitas teks/infografis paling bagus
#   gemini-3.1-flash-image   -> flash generasi 3.1 (lebih baik dari -lite)
# Hindari varian "-lite-image": lebih lemah merender teks pada infografis.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# CATATAN kalau gambar gagal dibuat:
# - Error 429 RESOURCE_EXHAUSTED = kuota/limit API key habis (cek billing/plan
#   di https://ai.google.dev/gemini-api/docs/rate-limits). Ini bukan bug kode.
# - Sekarang UI menampilkan pesan error aslinya, jadi ketahuan penyebabnya.

# Opsional: kalau nanti pakai OpenAI untuk gambar
# OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=gpt-image-1
